---
import { CONTACT_INFO, WHATSAPP_MESSAGES } from "../constants.js";
---

<footer class="bg-[#0a2540] text-white py-16 px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-12 mb-12 pb-12 border-b border-gray-700">
    <div>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-white bg-opacity-20 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 7c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-bold">INSTITUTO</p>
          <p class="font-serif text-lg font-bold">ELYON</p>
        </div>
      </div>
      <p class="text-sm text-gray-300 mb-6 leading-relaxed">
        Centro de Excelência em Dependência Química, Saúde Mental e Comportamento Humano. Reconstruindo vidas, restaurando famílias e promovendo dignidade.
      </p>
      <div class="flex gap-4">
        <a href="#" class="text-gray-300 hover:text-white transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.39v-1.2h-2.84v8.37h2.84v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.84M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z" />
          </svg>
        </a>
        <a href="#" class="text-gray-300 hover:text-white transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
        <a href="#" class="text-gray-300 hover:text-white transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 002.856-3.515A9.957 9.957 0 0022.46 2.312a4.969 4.969 0 01-1.604.454 4.948 4.948 0 002.166-2.725c-.951.564-2.005.974-3.127 1.195a4.948 4.948 0 00-8.506 4.513A14.025 14.025 0 011.671 3.149a4.927 4.927 0 001.523 6.574 4.903 4.903 0 01-2.229-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417A9.868 9.868 0 010 19.54a13.998 13.998 0 007.618 2.23c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
          </svg>
        </a>
      </div>
    </div>

    <div>
      <h4 class="font-bold text-lg mb-6">Links Rápidos</h4>
      <ul class="space-y-3 text-sm">
        <li><a href="/" class="text-gray-300 hover:text-white transition">Início</a></li>
        <li><a href="/#quem-somos" class="text-gray-300 hover:text-white transition">Quem Somos</a></li>
        <li><a href="/tratamentos" class="text-gray-300 hover:text-white transition">Tratamentos</a></li>
        <li><a href="/familias" class="text-gray-300 hover:text-white transition">Famílias</a></li>
        <li><a href="/resgate" class="text-gray-300 hover:text-white transition">Resgate Humanizado</a></li>
        <li><a href="/#contato" class="text-gray-300 hover:text-white transition">Contato</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-bold text-lg mb-6">Atendimento 24 Horas</h4>
      <ul class="space-y-4 text-sm">
        <li class="flex gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
          </svg>
          <a href={`tel:${CONTACT_INFO.phone}`} class="text-gray-300 hover:text-white transition">{CONTACT_INFO.formattedPhone}</a>
        </li>
        <li class="flex gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004c-1.025 0-2.031.313-2.896.893l-.207.124-2.15-.561.569 2.08.13.208a4.908 4.908 0 00-.398 2.326c0 2.7 2.201 4.9 4.9 4.9 1.308 0 2.541-.527 3.468-1.447.927-.92 1.439-2.155 1.439-3.468 0-2.699-2.201-4.9-4.9-4.9zm0-1.952c1.23 0 2.455.382 3.476 1.08l.248.153 2.654-.692-.683 2.598.145.233a6.87 6.87 0 011.019 3.555c0 3.89-3.168 7.057-7.057 7.057-1.954 0-3.814-.787-5.146-2.118-1.332-1.331-2.118-3.19-2.118-5.145 0-3.89 3.168-7.058 7.057-7.058z" />
          </svg>
          <a href={`${CONTACT_INFO.whatsappBaseUrl}${encodeURIComponent(WHATSAPP_MESSAGES.footer)}`} class="text-gray-300 hover:text-white transition">(51) 99999-9999</a>
        </li>
        <li class="flex gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
          </svg>
          <a href={`mailto:${CONTACT_INFO.email}`} class="text-gray-300 hover:text-white transition">{CONTACT_INFO.email}</a>
        </li>
        <li class="flex gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
          </svg>
          <span class="text-gray-300">Atendimento em todo o RS</span>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-bold text-lg mb-6">Compromisso com a Ética</h4>
      <div class="space-y-4">
        <div class="flex gap-3">
          <svg class="w-6 h-6 flex-shrink-0 text-[#0f4c5c]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
          </svg>
          <div>
            <p class="font-bold text-sm">Baseado em Evidências</p>
            <p class="text-xs text-gray-400">Métodos cientificamente comprovados</p>
          </div>
        </div>
        <div class="flex gap-3">
          <svg class="w-6 h-6 flex-shrink-0 text-[#0f4c5c]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
          </svg>
          <div>
            <p class="font-bold text-sm">Direitos Humanos</p>
            <p class="text-xs text-gray-400">Respeito e dignidade garantidos</p>
          </div>
        </div>
        <div class="flex gap-3">
          <svg class="w-6 h-6 flex-shrink-0 text-[#0f4c5c]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
          </svg>
          <div>
            <p class="font-bold text-sm">LGPD Adequado</p>
            <p class="text-xs text-gray-400">Privacidade de dados protegida</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center text-xs text-gray-400">
    <p>&copy; 2026 Instituto Elyon. Todos os direitos reservados.</p>
    <div class="flex gap-6 mt-4 md:mt-0">
      <a href="#" class="hover:text-white transition">Política de Privacidade</a>
      <a href="#" class="hover:text-white transition">Termos de Uso</a>
      <a href="#" class="hover:text-white transition">Canal de Denúncias</a>
    </div>
  </div>
</footer>