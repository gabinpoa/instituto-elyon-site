---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Lato:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "@id": "https://www.institutoelyon.com.br/#professionalservice",
        "name": "Instituto Elyon",
        "image": "https://www.institutoelyon.com.br/assets/images/og-image.jpg",
        "description": "Consultoria especializada, suporte familiar, serviço de resgate humanizado 24h and direcionamento para comunidades terapêuticas parceiras no Rio Grande do Sul.",
        "url": "https://www.institutoelyon.com.br",
        "telephone": "+55-51-3000-0000",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. Carlos Gomes, 1000",
          "addressLocality": "Porto Alegre",
          "addressRegion": "RS",
          "postalCode": "90480-001",
          "addressCountry": "BR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "-30.0277",
          "longitude": "-51.1784"
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "00:00",
          "closes": "23:59"
        },
        "areaServed": {
          "@type": "AdministrativeArea",
          "name": "Rio Grande do Sul"
        },
        "knowsAbout": [
          "Consultoria em Dependência Química",
          "Direcionamento e Encaminhamento para Comunidades Terapêuticas",
          "Suporte e Orientação Familiar",
          "Acompanhamento Terapêutico",
          "Resgate Humanizado 24h"
        ]
      }
    </script>
    <style>
      * {
        font-family: "Lato", sans-serif;
      }

      .font-serif {
        font-family: "Merriweather", serif;
      }

      .scroll-smooth {
        scroll-behavior: smooth;
      }
    </style>
  </head>
  <body class="bg-white">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
