---
import LayoutBase from "../layouts/LayoutBase.astro";
---

<LayoutBase title="Resgate Humanizado - Emergência 24h">

<style>
  /* Animação de pulso para o botão de emergência */
  @keyframes pulse-emergency {
    0% {
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    50% {
      box-shadow: 0 0 0 15px rgba(239, 68, 68, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
    }
  }

  .btn-emergency {
    animation: pulse-emergency 2s infinite;
  }

  /* Badge com animação de brilho */
  @keyframes glow-badge {
    0%,
    100% {
      box-shadow: 0 0 5px rgba(239, 68, 68, 0.5);
    }
    50% {
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.9);
    }
  }

  .badge-emergency {
    animation: glow-badge 2s infinite;
  }

  /* Gradiente para o fundo do hero */
  .hero-gradient {
    background: linear-gradient(135deg, #0a2540 0%, #0f4c5c 100%);
  }

  /* Efeito de ícone com fundo */
  .icon-circle {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background-color: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }
</style>
    <!-- SEÇÃO HERO EMERGÊNCIA -->
    <section class="hero-gradient py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <!-- Badge de Emergência -->
        <div class="flex justify-center mb-8">
          <div
            class="badge-emergency inline-flex items-center gap-2 bg-red-600 text-white px-4 py-2 rounded-full text-sm font-bold"
          >
            <span
              class="inline-block w-2 h-2 bg-red-200 rounded-full animate-pulse"
            ></span>
            PLANTÃO DE EMERGÊNCIA 24H
          </div>
        </div>

        <!-- Título de Impacto -->
        <div class="text-center mb-12">
          <h1
            class="serif-title text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6"
          >
            Serviço de Resgate Humanizado
          </h1>
          <p class="text-xl text-gray-100 max-w-3xl mx-auto">
            Quando pedir ajuda se torna urgente.
          </p>
        </div>

        <!-- Botão de Chamada Massivo -->
        <div class="flex justify-center mb-16">
          <button
            class="btn-emergency bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-8 sm:px-12 rounded-lg text-lg sm:text-xl transition-colors duration-300 flex items-center gap-3 shadow-lg"
          >
            <svg
              class="w-6 h-6 sm:w-8 sm:h-8"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773c.058.3.102.605.142.91.08.86.14 1.74.177 2.612.04.921.045 1.83.008 2.718-.037.888-.084 1.75-.151 2.584a1 1 0 01-.923.807l-2.746.205a1 1 0 01-1.029-.896c-.117-1.879-.043-3.955.015-5.94.056-1.98.132-3.944.214-5.85.016-.355-.021-.708-.084-1.056H3a1 1 0 01-1-1V3z"
              />
            </svg>
            LIGAR PARA A CENTRAL DE RESGATE
            <br class="hidden sm:block" />
            <span class="text-base sm:text-lg">(0800 123 4567)</span>
          </button>
        </div>

        <!-- Grid de Garantias Legais - 3 Colunas -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          <!-- Card 1: Abordagem Ética -->
          <div
            class="bg-white rounded-lg p-6 sm:p-8 shadow-md hover:shadow-lg transition-shadow"
          >
            <div class="icon-circle mb-4 mx-auto">
              <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
            <h3
              class="serif-title text-lg font-bold text-gray-900 text-center mb-3"
            >
              Abordagem Ética e Sem Coerção
            </h3>
            <p class="text-gray-700 text-center text-sm leading-relaxed">
              Respeito integral à autonomia e dignidade do paciente em todos os
              momentos da intervenção.
            </p>
          </div>

          <!-- Card 2: Segurança Física e Emocional -->
          <div
            class="bg-white rounded-lg p-6 sm:p-8 shadow-md hover:shadow-lg transition-shadow"
          >
            <div class="icon-circle mb-4 mx-auto">
              <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
            <h3
              class="serif-title text-lg font-bold text-gray-900 text-center mb-3"
            >
              Segurança Física e Emocional
            </h3>
            <p class="text-gray-700 text-center text-sm leading-relaxed">
              Equipe treinada para garantir proteção integral do paciente
              durante toda a abordagem.
            </p>
          </div>

          <!-- Card 3: Preservação da Integridade -->
          <div
            class="bg-white rounded-lg p-6 sm:p-8 shadow-md hover:shadow-lg transition-shadow"
          >
            <div class="icon-circle mb-4 mx-auto">
              <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
            <h3
              class="serif-title text-lg font-bold text-gray-900 text-center mb-3"
            >
              Preservação da Integridade do Paciente
            </h3>
            <p class="text-gray-700 text-center text-sm leading-relaxed">
              Sigilo, confidencialidade e respeito aos direitos legais
              garantidos em conformidade com a lei.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Seção adicional com contexto (opcional) -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2
          class="serif-title text-3xl font-bold text-gray-900 mb-6 text-center"
        >
          Por que contar conosco?
        </h2>
        <p class="text-gray-700 text-lg leading-relaxed text-center mb-8">
          Nossa equipe de resgate humanizado é especializada em intervenções de
          alta complexidade, combinando expertise técnica com sensibilidade
          emocional. Operamos 24 horas por dia, 7 dias por semana, com resposta
          rápida e garantia de sigilo profissional.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div>
            <p class="text-3xl font-bold text-red-600">200+</p>
            <p class="text-gray-600 text-sm">Resgates realizados</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-red-600">98%</p>
            <p class="text-gray-600 text-sm">Taxa de sucesso</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-red-600">24h</p>
            <p class="text-gray-600 text-sm">Disponibilidade</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-red-600">15+</p>
            <p class="text-gray-600 text-sm">Anos de experiência</p>
          </div>
        </div>
      </div>
    </section>
</LayoutBase>
